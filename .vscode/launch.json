{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch BOS app",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/src/bos"
    },
    {
      "name": "Attach to BOS process",
      "type": "go",
      "request": "attach",
      "mode": "local",
      "processId": "${command:pickProcess}"
    }
  ]
}
